# Get your free Mapbox token at https://mapbox.com → Account → Tokens
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# (Optional) Sentinel Hub — enables real historical satellite imagery in Before/After comparison
# Sign up free at https://www.sentinel-hub.com/
# Dashboard → Account → OAuth clients → New OAuth client (select SPA, allow all domains)
VITE_SENTINEL_HUB_CLIENT_ID=your_client_id_here
VITE_SENTINEL_HUB_CLIENT_SECRET=your_client_secret_here

# (Optional) AI Insights — Groq (primary) and OpenRouter (fallback)
# Groq: https://console.groq.com/ — OpenRouter: https://openrouter.ai/keys
VITE_GROQ_API_KEY=your_groq_key
VITE_OPENROUTER_API_KEY=your_openrouter_key

# (Optional) News — NewsAPI.org for area/conservation news (https://newsapi.org/register)
VITE_NEWS_API_KEY=your_newsapi_key